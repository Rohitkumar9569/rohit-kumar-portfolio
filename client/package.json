{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "copy-pdf-worker": "copyfiles -f node_modules/react-pdf/node_modules/pdfjs-dist/build/pdf.worker.mjs public/",
    "tailwind": "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "dev": "npm run copy-pdf-worker && npm-run-all -p tailwind vite",
    "vite": "vite",
    "prebuild": "npm run copy-pdf-worker",
    "build": "vite build",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "desktop:dev": "npm run build && ELECTRON_START_URL=http://localhost:5173 electron .",
    "desktop:pack": "npm run build && electron-builder",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/multer": "^2.0.0",
    "@types/three": "^0.180.0",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.16.1",
    "cmdk": "^1.0.0",
    "framer-motion": "^11.18.2",
    "lenis": "^1.3.11",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.30.1",
    "react-scroll": "^1.9.0",
    "react-simple-typewriter": "^5.0.1",
    "react-textarea-autosize": "^8.5.9",
    "react-tsparticles": "^2.12.2",
    "react-virtuoso": "^4.14.1",
    "three": "^0.167.1",
    "tsparticles-engine": "^2.12.0",
    "tsparticles-slim": "^2.12.0",
    "vaul": "^1.1.2",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.myblueprintportfolio.app",
    "productName": "Rohit Kumar Study Hub",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/react-scroll": "^1.8.10",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.14"
  }
}
