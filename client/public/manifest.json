      "description": "Open saved and offline study resources.",
      "url": "/app/library",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Open Papers",
      "short_name": "Papers",
      "description": "Open PYQs and previous papers.",
