NODE_ENV=development
PORT=5001

# Required
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/myblueprint
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated frontend origins allowed by CORS.
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.example

# Optional production controls
ENABLE_DAILY_JOURNEY_CRON=true
RATE_LIMIT_BUCKET_LIMIT=20000

# Google login
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=your-google-oauth-client-id.apps.googleusercontent.com

# AI providers used by Study Hub chat and enrichment flows
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
XAI_API_KEY=
XAI_MODEL=grok-3-mini-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
AI_PROVIDER_TIMEOUT_MS=9000

# Daily journey/news enrichment
NEWSAPI_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
PYQ_DB_PATH=

# Uploads and PDF assets
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Contact form email notification
RESEND_API_KEY=
RESEND_EMAIL_FROM=
CONTACT_EMAIL_TO=
ADMIN_EMAIL=
